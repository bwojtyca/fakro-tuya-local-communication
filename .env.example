# Configuration for the Fakro-Tuya-MQTT bridge.
# Copy this file to `.env` and fill in the real values.
# The `.env` file is git-ignored and never committed to the repository.

# --- Tuya device (local communication) ---
FAKRO_DEVICE_ID=your_device_id
FAKRO_LOCAL_KEY=your_local_key
FAKRO_DEVICE_IP=192.168.x.x
# Tuya protocol version (default 3.3)
FAKRO_TUYA_VERSION=3.3

# --- MQTT broker ---
FAKRO_MQTT_HOST=192.168.x.x
FAKRO_MQTT_PORT=1883
FAKRO_MQTT_USER=mqtt_user
FAKRO_MQTT_PASS=mqtt_password

# --- MQTT topics (optional, defaults to fakro/window) ---
FAKRO_BASE_TOPIC=fakro/window

# --- Deploy (used by deploy/deploy.sh) ---
# SSH host of the LXC container, application dir and venv dir on the container.
FAKRO_DEPLOY_HOST=root@192.168.x.x
FAKRO_DEPLOY_DIR=/opt/fakro-bridge
FAKRO_VENV_DIR=/opt/tuya-env
