# Konfiguracja mostu Fakro-Tuya-MQTT.
# Skopiuj ten plik do `.env` i uzupełnij prawdziwymi wartościami.
# Plik `.env` jest ignorowany przez git i NIE trafia do repozytorium.

# --- Urządzenie Tuya (komunikacja lokalna) ---
FAKRO_DEVICE_ID=twoj_device_id
FAKRO_LOCAL_KEY=twoj_local_key
FAKRO_DEVICE_IP=192.168.x.x
# Wersja protokołu Tuya (domyślnie 3.3)
FAKRO_TUYA_VERSION=3.3

# --- Broker MQTT ---
FAKRO_MQTT_HOST=192.168.x.x
FAKRO_MQTT_PORT=1883
FAKRO_MQTT_USER=uzytkownik_mqtt
FAKRO_MQTT_PASS=haslo_mqtt

# --- Topiki MQTT (opcjonalne, domyślnie fakro/window) ---
FAKRO_BASE_TOPIC=fakro/window

# --- Deploy (używane przez deploy/deploy.sh) ---
# Host SSH kontenera LXC, katalog aplikacji i katalog venv na kontenerze.
FAKRO_DEPLOY_HOST=root@192.168.x.x
FAKRO_DEPLOY_DIR=/opt/fakro-bridge
FAKRO_VENV_DIR=/opt/tuya-env
